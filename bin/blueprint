#!/usr/bin/env bash
# Blueprint CLI wrapper — handles PYTHONPATH for plugin dependencies
set -euo pipefail

# If running from plugin install, use plugin data dir for dependencies
if [ -n "${CLAUDE_PLUGIN_DATA:-}" ]; then
  SITE_PACKAGES="${CLAUDE_PLUGIN_DATA}/site-packages"
  if [ -d "$SITE_PACKAGES" ]; then
    export PYTHONPATH="${SITE_PACKAGES}:${PYTHONPATH:-}"
  fi
fi

# Find the script — either relative to this wrapper (plugin) or in PATH
SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
exec python3 "${SCRIPT_DIR}/scripts/blueprint.py" "$@"
